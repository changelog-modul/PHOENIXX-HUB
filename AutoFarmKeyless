--====================================================
-- 🎁 AUTO GIFT SYSTEM (RESTORED + FIXED)
--====================================================

local function getChar()
    return player.Character or player.CharacterAdded:Wait()
end

local function isWeightTool(tool)
    return weightFolder:FindFirstChild(tool.Name) ~= nil
end

local function silentEquip(tool)
    local char = getChar()
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hum then return end

    hum:EquipTool(tool)
    task.wait()

    local handle = tool:FindFirstChild("Handle")
    if handle then
        handle.Transparency = 1
        handle.CanCollide = false
        handle.Massless = true
        handle.Size = Vector3.new(0.05,0.05,0.05)
    end
end

local function unequipAll()
    local char = getChar()
    for _,v in ipairs(char:GetChildren()) do
        if v:IsA("Tool") then
            v.Parent = backpack
        end
    end
end

local function getRarity(tool)
    local model = tool:FindFirstChild(tool.Name)

    if model
    and model:FindFirstChild("Root")
    and model.Root:FindFirstChild("EntityGUI")
    and model.Root.EntityGUI:FindFirstChild("Frame")
    and model.Root.EntityGUI.Frame:FindFirstChild("RarityLabel") then
        return string.lower(model.Root.EntityGUI.Frame.RarityLabel.Text)
    end
end

