--====================================================
-- 💀 FREEZE GUI (KEEP YOUR ORIGINAL)
--====================================================

local gui = player:WaitForChild("PlayerGui")
local backpackGui = gui:WaitForChild("Backpack")

local frozenBar, frozenBag
local freezeDone = false
local bagVisibleState = false

local function freezeBackpack()
    if freezeDone then return end

    local bar = backpackGui:FindFirstChild("Bar")
    local bag = backpackGui:FindFirstChild("Backpack")

    if bar then
        frozenBar = bar:Clone()
        frozenBar.Parent = backpackGui
        frozenBar.Visible = bar.Visible
    end

    if bag then
        bagVisibleState = bag.Visible
        frozenBag = bag:Clone()
        frozenBag.Parent = backpackGui
        frozenBag.Visible = bagVisibleState
    end

    freezeDone = true
end

freezeBackpack()

RunService.RenderStepped:Connect(function()
    if frozenBar then frozenBar.Visible = true end
    if frozenBag then frozenBag.Visible = bagVisibleState end
end)

